{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
	"resolvePackageJsonExports": true,
	"declaration": true,
	"removeComments": true,
	"sourceMap": true,
	"noImplicitAny": true,
	"strictBindCallApply": true,
	// allow file generation
	"noEmit": false,
	"rootDir": "./src",
	"outDir": "./dist",
	//	"outDir": "../../dist/apps/api-gateway",
	"paths": {
	  "@/*": [
		"./src/*"
	  ]
	}
  },
  "include": [
	"src/**/*"
  ]
}